# IMA OpenAPI 凭证
IMA_OPENAPI_CLIENTID=replace_with_client_id
IMA_OPENAPI_APIKEY=replace_with_api_key

# Zotero Web API 凭证
ZOTERO_API_KEY=replace_with_24_character_key
ZOTERO_USER_ID=replace_with_numeric_user_id
ZOTERO_API_BASE_URL=https://api.zotero.org
ZOTERO_LOCAL_BASE_URL=http://127.0.0.1:23119
ZOTERO_SYNC_MODE=index-only
ZOTERO_HELPER_SCRIPT=C:/path/to/zotero.py

# 可选：覆盖随仓库提供的 IMA helper 路径
IMA_SKILL_DIR=vendor/ima-skill
